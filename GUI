--// DakaitUI Library (V3 - Asset Pack Integrated)
local DakaitUI = {}
DakaitUI.__index = DakaitUI

local UIS = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")

-- ASSET IDs (Matching your Pack)
local ASSETS = {
    Logo = "rbxassetid://13864752250", -- Indian Skull Logo
    MainPanel = "rbxassetid://6031068433", -- Metal Texture
    ButtonImg = "rbxassetid://6031094678", -- Rust Button
    ToggleOn = "rbxassetid://13864755672", -- Neon Orange Toggle
    ToggleOff = "rbxassetid://13864756891", -- Grey Toggle
}

local Theme = {
    Main = Color3.fromRGB(25, 25, 25),
    Secondary = Color3.fromRGB(35, 35, 35),
    Accent = Color3.fromRGB(255, 140, 40), -- Neon Orange
    Text = Color3.fromRGB(240, 240, 240)
}

function DakaitUI:CreateWindow(title)
    local Window = setmetatable({}, DakaitUI)

    local gui = Instance.new("ScreenGui", CoreGui)
    gui.Name = "Dakait_Final"
    gui.IgnoreGuiInset = true

    -- Main Frame with Pack Texture
    local main = Instance.new("ImageLabel", gui)
    main.Name = "Main"
    main.Size = UDim2.new(0, 540, 0, 360)
    main.Position = UDim2.fromScale(0.5, 0.5)
    main.AnchorPoint = Vector2.new(0.5, 0.5)
    main.BackgroundColor3 = Theme.Main
    main.Image = ASSETS.MainPanel
    main.ImageColor3 = Color3.fromRGB(80, 80, 80) -- Darker metal feel
    main.ScaleType = Enum.ScaleType.Slice
    main.SliceCenter = Rect.new(10, 10, 10, 10)
    main.Active = true
    
    local corner = Instance.new("UICorner", main)
    
    -- Logo from Pack
    local logo = Instance.new("ImageLabel", main)
    logo.Size = UDim2.new(0, 40, 0, 40)
    logo.Position = UDim2.new(0, 10, 0, 5)
    logo.Image = ASSETS.Logo
    logo.BackgroundTransparency = 1

    local titleLabel = Instance.new("TextLabel", main)
    titleLabel.Text = title or "DAKAIT"
    titleLabel.Size = UDim2.new(0, 200, 0, 45)
    titleLabel.Position = UDim2.new(0, 55, 0, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.TextColor3 = Theme.Accent
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 18
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left

    -- Content Areas
    local sidebar = Instance.new("Frame", main)
    sidebar.Size = UDim2.new(0, 150, 1, -50)
    sidebar.Position = UDim2.new(0, 0, 0, 50)
    sidebar.BackgroundTransparency = 1
    local sideLayout = Instance.new("UIListLayout", sidebar)
    sideLayout.Padding = UDim.new(0, 5)
    sideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

    local content = Instance.new("Frame", main)
    content.Size = UDim2.new(1, -160, 1, -60)
    content.Position = UDim2.new(0, 155, 0, 55)
    content.BackgroundTransparency = 1

    -- Window Dragging
    local dragging, dragStart, startPos
    main.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = i.Position; startPos = main.Position
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = i.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

    Window.Sidebar = sidebar
    Window.Content = content
    Window.Tabs = {}
    return Window
end

function DakaitUI:CreateTab(name)
    local tab = {}
    
    -- Tab Button (Metal Style)
    local btn = Instance.new("ImageButton", self.Sidebar)
    btn.Size = UDim2.new(1, -20, 0, 35)
    btn.Image = ASSETS.ButtonImg
    btn.ImageColor3 = Theme.Secondary
    btn.ScaleType = Enum.ScaleType.Slice
    btn.SliceCenter = Rect.new(10, 10, 10, 10)
    
    local btnText = Instance.new("TextLabel", btn)
    btnText.Size = UDim2.new(1, 0, 1, 0)
    btnText.BackgroundTransparency = 1
    btnText.Text = name
    btnText.TextColor3 = Theme.Text
    btnText.Font = Enum.Font.GothamMedium
    btnText.TextSize = 13

    local page = Instance.new("ScrollingFrame", self.Content)
    page.Size = UDim2.new(1, 0, 1, 0)
    page.BackgroundTransparency = 1
    page.Visible = false
    page.ScrollBarThickness = 0
    Instance.new("UIListLayout", page).Padding = UDim.new(0, 10)

    btn.MouseButton1Click:Connect(function()
        for _, t in ipairs(self.Tabs) do t.Page.Visible = false end
        page.Visible = true
    end)

    tab.Page = page
    table.insert(self.Tabs, tab)
    if #self.Tabs == 1 then page.Visible = true end

    -- Toggle with Pack Icons
    function tab:AddToggle(text, callback)
        local state = false
        local container = Instance.new("Frame", page)
        container.Size = UDim2.new(1, 0, 0, 40)
        container.BackgroundTransparency = 1
        
        local label = Instance.new("TextLabel", container)
        label.Text = text
        label.Size = UDim2.new(1, -50, 1, 0)
        label.BackgroundTransparency = 1
        label.TextColor3 = Theme.Text
        label.Font = Enum.Font.Gotham
        label.TextSize = 14
        label.TextXAlignment = Enum.TextXAlignment.Left

        local toggleImg = Instance.new("ImageButton", container)
        toggleImg.Size = UDim2.new(0, 40, 0, 20)
        toggleImg.Position = UDim2.new(1, -45, 0.5, -10)
        toggleImg.Image = ASSETS.ToggleOff
        toggleImg.BackgroundTransparency = 1

        toggleImg.MouseButton1Click:Connect(function()
            state = not state
            toggleImg.Image = state and ASSETS.ToggleOn or ASSETS.ToggleOff
            pcall(callback, state)
        end)
    end

    return tab
end

