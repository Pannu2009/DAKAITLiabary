local cloneref = (cloneref or clonereference or function(instance) return instance end)

local RunService = cloneref(game:GetService("RunService"))
local HttpService = cloneref(game:GetService("HttpService"))

local Window 
local DakaitConfig = {
    Folder = nil,
    Path = nil,
    Configs = {},
    Parser = {
        -- This handles how each UI element is saved/loaded
        Colorpicker = {
            Save = function(obj) return {__type = "Colorpicker", value = obj.Default:ToHex(), transparency = obj.Transparency} end,
            Load = function(el, data) if el.Update then el:Update(Color3.fromHex(data.value), data.transparency) end end
        },
        Dropdown = {
            Save = function(obj) return {__type = "Dropdown", value = obj.Value} end,
            Load = function(el, data) if el.Select then el:Select(data.value) end end
        },
        Slider = {
            Save = function(obj) return {__type = "Slider", value = obj.Value.Default} end,
            Load = function(el, data) if el.Set then el:Set(tonumber(data.value)) end end
        },
        Toggle = {
            Save = function(obj) return {__type = "Toggle", value = obj.Value} end,
            Load = function(el, data) if el.Set then el:Set(data.value) end end
        },
    }
}

function DakaitConfig:Init(WindowTable)
    if not WindowTable.Folder then return warn("[ DakaitLib ] Window.Folder missing!") end
    
    Window = WindowTable
    DakaitConfig.Folder = Window.Folder
    -- PATH REBRAND: Saving to your own folder
    DakaitConfig.Path = "DakaitLib/" .. tostring(DakaitConfig.Folder) .. "/configs/"
    
    if not isfolder(DakaitConfig.Path) then
        makefolder("DakaitLib/")
        makefolder("DakaitLib/" .. tostring(DakaitConfig.Folder))
        makefolder(DakaitConfig.Path)
    end
    
    return DakaitConfig
end

-- [ Rest of the Config Functions remain high-performance ]
-- We will use this module to allow users to Save/Load their Dakait Hub settings.

return DakaitConfig
